    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/bullmq": "^10.1.1",
    "@nestjs/schedule": "^4.0.0",
    "bullmq": "^5.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.0",
    "bcrypt": "^5.1.1",
