    "@crm/shared-core": "workspace:*",
    "@crm/shared-types": "workspace:*",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/microservices": "^10.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "bcrypt": "^5.1.1",
    "ioredis": "^5.3.2",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
